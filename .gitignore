# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# mypy / Pyre
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Jupyter
.ipynb_checkpoints
*.ipynb

# ── Large files & data ──────────────────────────────────────
model/
data/
datasets/
third_party/
singularity/
*.sif

# Videos & media (never commit large binaries)
*.mp4
*.MP4
*.avi
*.mov
*.mkv
*.gif

# Generated data files
*.npz
*.npy

# ── Input / Output ──────────────────────────────────────────
# Keep folder structure with .gitkeep, ignore contents (videos, JSONs, etc.)
input/*
!input/.gitkeep
!input/README.md

output/*
!output/.gitkeep

# ── Allow specific config & demo files ──────────────────────
!conda_linux.yaml
!config/config.yaml

# Allow all files in the demo folder
!demo/
!demo/**/*

# ── Misc junk ───────────────────────────────────────────────
*.pub
*.pub.*
*.log
tmp_vis.ipynb
tmp.sh
